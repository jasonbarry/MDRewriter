{
  "name": "mdrewriter",
  "version": "1.0.1",
  "description": "Fast streaming HTML-to-markdown converter, 100% CommonMark + GFM",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "markdown",
    "html-to-markdown",
    "converter"
  ],
  "author": "Jason Barry",
  "license": "MIT",
  "scripts": {
    "bench": "tsx test/benchmark.bench.ts",
    "bench:parser": "tsx test/parser.bench.ts",
    "build": "pnpm typecheck && pnpm lint && pnpm test && tsc",
    "download:fixtures": "tsx script/download-fixtures.ts",
    "lint": "biome check --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.test.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "htmlparser2": "10.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "25.5.0",
    "@types/turndown": "5.0.6",
    "commonmark": "0.31.2",
    "commonmark-spec": "0.31.2",
    "htmlparser-benchmark": "1.1.3",
    "micromark": "4.0.2",
    "micromark-extension-gfm": "3.0.0",
    "node-html-markdown": "2.0.0",
    "tsx": "4.21.0",
    "turndown": "7.2.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
